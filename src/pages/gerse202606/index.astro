---
// Page d'inscription à la formation RSE – GERSE juin 2025
// URL volontairement non intuitive – noindex, hors sitemap
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Formation RSE — mesurer, améliorer, communiquer</title>
  <!-- Page privée : pas d'indexation -->
  <meta name="robots" content="noindex, nofollow" />
  <style>
    :root {
      --primary:      #007A7A;
      --primary-dark: #005F5F;
      --text:         #1A1A1A;
      --gray:         #64748B;
      --light:        #F8FAFC;
      --radius:       8px;
    }
    *, *::before, *::after { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--light);
      color: var(--text);
      line-height: 1.6;
    }
    /* ── Header ── */
    header {
      background: var(--primary);
      color: white;
      padding: 1.2rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    header img { height: 48px; width: auto; }
    header span { font-size: 1.1rem; font-weight: 600; opacity: 0.95; }
    /* ── Conteneur principal ── */
    .page { max-width: 820px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }
    /* ── Présentation ── */
    .intro { background: white; border-radius: var(--radius); padding: 2rem; box-shadow: 0 2px 12px rgba(0,0,0,.07); margin-bottom: 2rem; }
    .intro h1 { color: var(--primary); font-size: 1.7rem; margin: 0 0 0.5rem; }
    .intro .subtitle { color: var(--gray); font-size: 1rem; margin: 0 0 1.5rem; }
    .programme { list-style: none; padding: 0; margin: 0; }
    .programme li {
      display: flex; align-items: flex-start; gap: 0.8rem;
      padding: 0.7rem 0; border-bottom: 1px solid #e2e8f0;
    }
    .programme li:last-child { border-bottom: none; }
    .num {
      flex-shrink: 0; width: 28px; height: 28px;
      background: var(--primary); color: white;
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-size: 0.85rem; font-weight: 700;
    }
    /* ── Formulaire ── */
    .form-card { background: white; border-radius: var(--radius); padding: 2rem; box-shadow: 0 2px 12px rgba(0,0,0,.07); }
    .form-card h2 { color: var(--primary); margin: 0 0 1.5rem; font-size: 1.3rem; }
    fieldset { border: none; padding: 0; margin: 0 0 1.5rem; }
    legend { font-weight: 600; margin-bottom: 0.8rem; color: var(--text); font-size: 1rem; }
    .session-option {
      display: flex; align-items: center; justify-content: space-between;
      border: 2px solid #e2e8f0; border-radius: var(--radius);
      padding: 0.8rem 1rem; margin-bottom: 0.6rem; cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
    }
    .session-option:has(input:checked) { border-color: var(--primary); background: #e6f4f4; }
    .session-option:has(input:disabled) { opacity: 0.5; cursor: not-allowed; background: #f1f5f9; }
    .session-option input[type="radio"] { margin-right: 0.7rem; accent-color: var(--primary); width: 1.1rem; height: 1.1rem; }
    .session-label { display: flex; align-items: center; gap: 0.5rem; flex: 1; }
    .places-badge {
      font-size: 0.8rem; padding: 0.2rem 0.6rem; border-radius: 20px;
      font-weight: 600; white-space: nowrap;
    }
    .places-badge.ok   { background: #dcfce7; color: #166534; }
    .places-badge.low  { background: #fef3c7; color: #92400e; }
    .places-badge.full { background: #fee2e2; color: #991b1b; }
    .places-badge.loading { background: #f1f5f9; color: var(--gray); }
    /* ── Email ── */
    .field { margin-bottom: 1.2rem; }
    .field label { display: block; font-weight: 600; margin-bottom: 0.4rem; font-size: 0.95rem; }
    .field input[type="email"] {
      width: 100%; padding: 0.65rem 0.9rem;
      border: 2px solid #e2e8f0; border-radius: var(--radius);
      font-size: 1rem; transition: border-color 0.2s;
      font-family: inherit;
    }
    .field input[type="email"]:focus { outline: none; border-color: var(--primary); }
    .field input[type="email"].invalid { border-color: #ef4444; }
    .hint { font-size: 0.82rem; color: var(--gray); margin-top: 0.3rem; display: block; }
    /* ── Consentement ── */
    .consent-block {
      background: #f8fafc; border: 1px solid #e2e8f0; border-radius: var(--radius);
      padding: 1rem 1.2rem; margin-bottom: 1.5rem; font-size: 0.9rem;
    }
    .consent-block label { display: flex; align-items: flex-start; gap: 0.7rem; cursor: pointer; }
    .consent-block input[type="checkbox"] { margin-top: 3px; accent-color: var(--primary); flex-shrink: 0; width: 1rem; height: 1rem; }
    .policy-toggle {
      background: none; border: none; color: var(--primary); cursor: pointer;
      text-decoration: underline; font-size: inherit; padding: 0; font-family: inherit;
    }
    .policy-text {
      margin-top: 0.8rem; padding: 0.8rem 1rem; background: white;
      border-radius: 6px; border: 1px solid #e2e8f0; font-size: 0.85rem;
      color: var(--gray); line-height: 1.7; display: none;
    }
    .policy-text.open { display: block; }
    /* ── Bouton ── */
    .btn-submit {
      width: 100%; padding: 0.9rem; background: var(--primary); color: white;
      border: none; border-radius: var(--radius); font-size: 1.05rem;
      font-weight: 700; cursor: pointer; transition: background 0.2s;
      font-family: inherit;
    }
    .btn-submit:hover:not(:disabled)  { background: var(--primary-dark); }
    .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; }
    /* ── Messages ── */
    .msg {
      display: none; border-radius: var(--radius); padding: 1rem 1.2rem;
      margin-top: 1.2rem; font-size: 0.95rem; line-height: 1.6;
    }
    .msg.success { background: #dcfce7; color: #166534; border: 1px solid #86efac; }
    .msg.error   { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
    .msg.info    { background: #e6f4f4; color: #005F5F; border: 1px solid #99d6d6; }
    .msg.show    { display: block; }
    /* ── Boutons de confirmation ── */
    .confirm-buttons { display: flex; gap: 0.8rem; margin-top: 1rem; }
    .btn-yes, .btn-no {
      padding: 0.6rem 1.2rem; border-radius: var(--radius);
      font-size: 0.95rem; font-weight: 600; cursor: pointer;
      border: 2px solid; font-family: inherit; transition: all 0.2s;
    }
    .btn-yes { background: var(--primary); color: white; border-color: var(--primary); }
    .btn-yes:hover { background: var(--primary-dark); border-color: var(--primary-dark); }
    .btn-no  { background: white; color: var(--primary); border-color: var(--primary); }
    .btn-no:hover { background: #e6f4f4; }
    /* ── Footer ── */
    footer {
      background: var(--primary); color: white; text-align: center;
      padding: 1.2rem; font-size: 0.85rem; margin-top: 3rem;
    }
    footer a { color: rgba(255,255,255,0.85); text-decoration: none; }
  </style>
</head>
<body>

<header>
  <img src="/images/Ycompris.jpg" alt="Logo Ycompris" />
  <span>Formation RSE</span>
</header>

<div class="page">

  <!-- Présentation de la formation -->
  <div class="intro">
    <h1>Formation RSE — mesurer, améliorer, communiquer</h1>
    <p class="subtitle">Session de 2 heures, animée par Yves Cavarec (Ycompris)</p>

    <ul class="programme">
      <li>
        <span class="num">1</span>
        <div><strong>Qu'est-ce que la RSE dans notre contexte</strong><br>
        <span style="color:var(--gray);font-size:0.9rem;">Cadre réglementaire, enjeux pour le groupe, ce qui nous concerne vraiment.</span></div>
      </li>
      <li>
        <span class="num">2</span>
        <div><strong>La RSE est déjà dans l'entreprise</strong><br>
        <span style="color:var(--gray);font-size:0.9rem;">Ce que vous faites déjà — et comment le voir sous l'angle RSE.</span></div>
      </li>
      <li>
        <span class="num">3</span>
        <div><strong>Mesurer, améliorer, communiquer</strong><br>
        <span style="color:var(--gray);font-size:0.9rem;">Données, indicateurs, processus simples pour progresser.</span></div>
      </li>
      <li>
        <span class="num">4</span>
        <div><strong>Communiquer avec crédibilité</strong><br>
        <span style="color:var(--gray);font-size:0.9rem;">Dire ce qu'on fait, preuves à l'appui — sans greenwashing.</span></div>
      </li>
      <li>
        <span class="num">5</span>
        <div><strong>Et maintenant ? La feuille de route</strong><br>
        <span style="color:var(--gray);font-size:0.9rem;">Prochaines étapes concrètes pour votre équipe et votre périmètre.</span></div>
      </li>
    </ul>
  </div>

  <!-- Formulaire d'inscription -->
  <div class="form-card">
    <h2>Choisissez votre créneau</h2>

    <form id="regForm" novalidate>

      <!-- Créneaux -->
      <fieldset>
        <legend>Créneaux disponibles <span style="font-weight:400;color:var(--gray);font-size:0.85rem;">(8 places max par session)</span></legend>

        <label class="session-option">
          <input type="radio" name="session" value="s1" required />
          <span class="session-label">Mardi 16 juin – 10h00-12h00</span>
          <span class="places-badge loading" id="badge-s1">…</span>
        </label>

        <label class="session-option">
          <input type="radio" name="session" value="s2" />
          <span class="session-label">Mardi 23 juin – 14h00-16h00</span>
          <span class="places-badge loading" id="badge-s2">…</span>
        </label>

        <label class="session-option">
          <input type="radio" name="session" value="s3" />
          <span class="session-label">Vendredi 26 juin – 10h00-12h00</span>
          <span class="places-badge loading" id="badge-s3">…</span>
        </label>

        <label class="session-option">
          <input type="radio" name="session" value="s4" />
          <span class="session-label">Jeudi 2 juillet – 10h00-12h00</span>
          <span class="places-badge loading" id="badge-s4">…</span>
        </label>
      </fieldset>

      <!-- Email -->
      <div class="field">
        <label for="email">Adresse email professionnelle</label>
        <input type="email" id="email" name="email" autocomplete="email"
               placeholder="prenom.nom@votreentreprise.com" />
        <span class="hint">Adresse email professionnelle sur domaine autorisé uniquement</span>
      </div>

      <!-- Consentement -->
      <div class="consent-block">
        <label>
          <input type="checkbox" id="consent" required />
          <span>
            J'accepte que mon adresse email soit utilisée uniquement pour organiser cette session de formation.
            <button type="button" class="policy-toggle" id="togglePolicy">Voir la politique de confidentialité</button>
          </span>
        </label>
        <div class="policy-text" id="policyText">
          <strong>Politique de confidentialité – Inscription formation RSE</strong><br/><br/>
          <strong>Données collectées :</strong> adresse email professionnelle uniquement.<br/>
          <strong>Finalité :</strong> organiser les sessions de formation RSE et vous envoyer une invitation calendrier.<br/>
          <strong>Destinataire :</strong> Yves Cavarec (Ycompris) uniquement. Aucune transmission à des tiers.<br/>
          <strong>Durée de conservation :</strong> les données sont supprimées au plus tard le 31 juillet 2026.<br/>
          <strong>Vos droits :</strong> pour demander la suppression de votre inscription, contactez
          <a href="mailto:contact@ycompris.com">contact@ycompris.com</a>.<br/>
          <strong>Base légale :</strong> consentement (RGPD, art. 6.1.a).
        </div>
      </div>

      <button type="submit" class="btn-submit" id="submitBtn">S'inscrire → recevoir l'invitation calendrier</button>
    </form>

    <!-- Message : conflit de créneau -->
    <div class="msg info" id="msgConflict">
      <strong>Vous êtes déjà inscrit</strong><br/>
      <span id="conflictText"></span>
      <div class="confirm-buttons">
        <button class="btn-yes" id="btnOui">Oui, modifier mon inscription</button>
        <button class="btn-no"  id="btnNon">Non, conserver mon créneau actuel</button>
      </div>
    </div>

    <!-- Message : succès -->
    <div class="msg success" id="msgSuccess"></div>

    <!-- Message : erreur -->
    <div class="msg error" id="msgError"></div>

  </div><!-- /form-card -->
</div><!-- /page -->

<footer>
  <a href="https://ycompris.com">ycompris.com</a> — Page réservée aux participants de la formation
</footer>

<script>
  // ── Chargement des disponibilités ─────────────────────────────────────────
  async function loadAvailability() {
    try {
      const res  = await fetch('/api/gerse-register');
      if (!res.ok) return;
      const data = await res.json();
      for (const [id, info] of Object.entries(data)) {
        const badge  = document.getElementById(`badge-${id}`);
        const input  = document.querySelector(`input[value="${id}"]`);
        if (!badge || !input) continue;
        badge.className = 'places-badge';
        if (info.full) {
          badge.textContent = 'Complet';
          badge.classList.add('full');
          input.disabled = true;
        } else if (info.available <= 2) {
          badge.textContent = `${info.available} place${info.available > 1 ? 's' : ''} restante${info.available > 1 ? 's' : ''}`;
          badge.classList.add('low');
        } else {
          badge.textContent = `${info.available} places`;
          badge.classList.add('ok');
        }
      }
    } catch (e) {
      // silencieux si l'API est indisponible
    }
  }
  loadAvailability();

  // ── Politique de confidentialité (toggle) ────────────────────────────────
  document.getElementById('togglePolicy').addEventListener('click', () => {
    const p = document.getElementById('policyText');
    p.classList.toggle('open');
    document.getElementById('togglePolicy').textContent =
      p.classList.contains('open') ? 'Masquer' : 'Voir la politique de confidentialité';
  });

  // ── Helpers UI ────────────────────────────────────────────────────────────
  function hideAll() {
    ['msgConflict', 'msgSuccess', 'msgError'].forEach(id => {
      document.getElementById(id).classList.remove('show');
    });
  }
  function showMsg(id, html = '') {
    hideAll();
    const el = document.getElementById(id);
    if (html) el.innerHTML = html;
    el.classList.add('show');
    el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
  function setLoading(on) {
    const btn = document.getElementById('submitBtn');
    btn.disabled = on;
    btn.textContent = on ? 'Inscription en cours…' : 'S\'inscrire → recevoir l\'invitation calendrier';
  }

  // ── Soumission du formulaire ──────────────────────────────────────────────
  let pendingSessionId = null;  // stocke le créneau en attente de confirmation

  async function sendRegistration(session_id, email, confirm_change = false) {
    setLoading(true);
    hideAll();
    try {
      const res  = await fetch('/api/gerse-register', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ email, session_id, confirm_change }),
      });
      const data = await res.json();

      if (!res.ok) {
        showMsg('msgError', `⚠️ ${data.error ?? 'Une erreur est survenue.'}`);
        return;
      }

      switch (data.status) {
        case 'success':
          showMsg('msgSuccess', `✅ ${data.message}`);
          document.getElementById('regForm').reset();
          pendingSessionId = null;
          loadAvailability();
          break;

        case 'already_same':
          showMsg('msgSuccess', `ℹ️ ${data.message}`);
          break;

        case 'full':
          showMsg('msgError', `⛔ ${data.message}`);
          loadAvailability();
          break;

        case 'conflict':
          pendingSessionId = session_id;
          document.getElementById('conflictText').textContent =
            `Vous êtes actuellement inscrit sur le créneau « ${data.current_session_label} ». ` +
            `Voulez-vous modifier pour « ${data.new_session_label} » ?`;
          showMsg('msgConflict');
          break;

        default:
          showMsg('msgError', `⚠️ ${data.message ?? data.error ?? 'Erreur inattendue.'}`);
      }
    } catch {
      showMsg('msgError', '⚠️ Impossible de contacter le serveur. Réessayez dans quelques instants.');
    } finally {
      setLoading(false);
    }
  }

  document.getElementById('regForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    hideAll();

    const session_id = document.querySelector('input[name="session"]:checked')?.value;
    const email      = document.getElementById('email').value.trim();
    const consent    = document.getElementById('consent').checked;

    // Validations côté client
    if (!session_id) {
      showMsg('msgError', '⚠️ Veuillez choisir un créneau.');
      return;
    }
    if (!email) {
      showMsg('msgError', '⚠️ Veuillez saisir votre adresse email.');
      return;
    }
    const domain = email.split('@')[1]?.toLowerCase();
    if (!['guyotenvironnement.com', 'guyotenergies.com', 'ycompris.com'].includes(domain)) {
      document.getElementById('email').classList.add('invalid');
      showMsg('msgError', '⚠️ Votre adresse email ne fait pas partie des domaines autorisés.');
      return;
    }
    document.getElementById('email').classList.remove('invalid');
    if (!consent) {
      showMsg('msgError', '⚠️ Veuillez accepter la politique de confidentialité.');
      return;
    }

    await sendRegistration(session_id, email, false);
  });

  // ── Boutons Oui / Non (modification de créneau) ───────────────────────────
  document.getElementById('btnOui').addEventListener('click', async () => {
    if (!pendingSessionId) return;
    const email = document.getElementById('email').value.trim();
    await sendRegistration(pendingSessionId, email, true);
  });

  document.getElementById('btnNon').addEventListener('click', () => {
    hideAll();
    pendingSessionId = null;
  });

  // Nettoie le style "invalid" à la saisie
  document.getElementById('email').addEventListener('input', () => {
    document.getElementById('email').classList.remove('invalid');
  });
</script>

</body>
</html>
